rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function reportKeys() {
      return [
        'reportId',
        'sessionId',
        'routeId',
        'stationId',
        'reporterUid',
        'observedArrivalAt',
        'submittedAt'
      ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function isRecentSubmittedAt(value) {
      return value <= request.time
        && value >= request.time - duration.value(2, 'h');
    }

    function isValidStationReport() {
      return hasAllowedKeys(reportKeys())
        && request.resource.data.reportId is string
        && request.resource.data.sessionId is string
        && request.resource.data.routeId is string
        && request.resource.data.stationId is string
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.observedArrivalAt is timestamp
        && request.resource.data.submittedAt is timestamp
        && isRecentSubmittedAt(request.resource.data.submittedAt);
    }

    match /station_reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStationReport();
      allow update, delete: if false;
    }

    match /session_status_snapshots/{sessionId} {
      allow read: if true;
      allow write: if false;

      match /predicted_stops/{stationId} {
        allow read: if true;
        allow write: if false;
      }
    }

  }
}
