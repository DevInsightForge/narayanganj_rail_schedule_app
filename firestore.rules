rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    match /train_sessions/{sessionId} {
      allow read: if true;
      allow write: if false;
    }

    match /station_reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn()
        && hasAllowedKeys([
          'reportId',
          'sessionId',
          'routeId',
          'stationId',
          'reporterUid',
          'observedArrivalAt',
          'submittedAt'
        ])
        && request.resource.data.reportId is string
        && request.resource.data.sessionId is string
        && request.resource.data.routeId is string
        && request.resource.data.stationId is string
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.observedArrivalAt is timestamp
        && request.resource.data.submittedAt is timestamp
        && request.resource.data.submittedAt <= request.time
        && request.resource.data.submittedAt >= request.time - duration.value(10, 'm');
      allow update, delete: if false;
    }

    match /session_status_snapshots/{sessionId} {
      allow read: if true;
      allow write: if false;

      match /predicted_stops/{stationId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /user_profiles/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && hasAllowedKeys(['uid', 'lastSeenAt', 'updatedAt'])
        && request.resource.data.uid == uid
        && (!('lastSeenAt' in request.resource.data) || request.resource.data.lastSeenAt is timestamp)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      allow delete: if false;
    }
  }
}
