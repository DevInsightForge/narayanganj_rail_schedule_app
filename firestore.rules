rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasAllowedKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function isValidAggregateConfidence() {
      return request.resource.data.confidence is map
        && request.resource.data.confidence.keys().hasOnly([
          'score',
          'sampleSize',
          'freshnessSeconds',
          'agreementScore'
        ])
        && request.resource.data.confidence.score is number
        && request.resource.data.confidence.sampleSize is number
        && request.resource.data.confidence.freshnessSeconds is number
        && request.resource.data.confidence.agreementScore is number;
    }

    function isValidStationBucket(bucket) {
      return bucket is map
        && bucket.keys().hasOnly([
          'stationId',
          'stationName',
          'sequence',
          'scheduledAt',
          'firstObservedAt',
          'lastObservedAt',
          'firstSubmittedAt',
          'lastSubmittedAt',
          'latestReportId',
          'latestDeviceId',
          'submissionCount',
          'delayMinutes'
        ])
        && bucket.stationId is string
        && bucket.stationName is string
        && bucket.sequence is number
        && bucket.scheduledAt is timestamp
        && bucket.firstObservedAt is timestamp
        && bucket.lastObservedAt is timestamp
        && bucket.firstSubmittedAt is timestamp
        && bucket.lastSubmittedAt is timestamp
        && bucket.latestReportId is string
        && bucket.latestDeviceId is string
        && bucket.submissionCount is number
        && bucket.submissionCount >= 1
        && bucket.submissionCount <= 10
        && bucket.delayMinutes is number;
    }

    function isValidSessionAggregate() {
      return hasAllowedKeys([
          'sessionId',
          'routeId',
          'directionId',
          'trainNo',
          'serviceDate',
          'updatedAt',
          'lastObservedAt',
          'delayMinutes',
          'delayStatus',
          'confidence',
          'freshnessSeconds',
          'reportCount',
          'stationCount',
          'stationBuckets'
        ])
        && request.resource.data.sessionId is string
        && request.resource.data.routeId is string
        && request.resource.data.directionId is string
        && request.resource.data.trainNo is number
        && request.resource.data.serviceDate is string
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.lastObservedAt == null ||
          request.resource.data.lastObservedAt is timestamp
        )
        && request.resource.data.delayMinutes is number
        && request.resource.data.delayStatus is string
        && isValidAggregateConfidence()
        && request.resource.data.freshnessSeconds is number
        && request.resource.data.reportCount is number
        && request.resource.data.stationCount is number
        && request.resource.data.stationBuckets is map;
    }

    function isValidSingleStationBucketMap() {
      return request.resource.data.stationBuckets is map
        && request.resource.data.stationBuckets.size() == 1
        && isValidStationBucket(
          request.resource.data.stationBuckets[
            request.resource.data.stationBuckets.keys()[0]
          ]
        );
    }

    function isValidSessionAggregateCreate() {
      return isValidSessionAggregate()
        && request.resource.data.reportCount == 1
        && request.resource.data.stationCount == 1
        && isValidSingleStationBucketMap();
    }

    function isValidSessionAggregateUpdate() {
      let changedStations = request.resource.data.stationBuckets
        .diff(resource.data.stationBuckets)
        .affectedKeys()
        ;
      let isServiceDayReset =
        request.resource.data.serviceDate != resource.data.serviceDate &&
        request.resource.data.reportCount == 1 &&
        request.resource.data.stationCount == 1 &&
        isValidSingleStationBucketMap();

      return isValidSessionAggregate()
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.routeId == resource.data.routeId
        && request.resource.data.directionId == resource.data.directionId
        && request.resource.data.trainNo == resource.data.trainNo
        && (
          isServiceDayReset
          || (
            request.resource.data.serviceDate == resource.data.serviceDate
            && changedStations.size() == 1
            && request.resource.data.reportCount == resource.data.reportCount + 1
            && (
              request.resource.data.stationCount == resource.data.stationCount ||
              request.resource.data.stationCount == resource.data.stationCount + 1
            )
          )
        );
    }

    match /session_status_snapshots/{sessionId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.sessionId == sessionId
        && isValidSessionAggregateCreate();
      allow update: if isSignedIn()
        && request.resource.data.sessionId == sessionId
        && isValidSessionAggregateUpdate();
      allow delete: if false;
    }
  }
}
